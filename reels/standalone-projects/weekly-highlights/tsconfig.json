{
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "allowJs": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "strict": true,
    "target": "ES2017",
    "jsx": "react",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
