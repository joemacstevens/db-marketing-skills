{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DB Content Calendar Entry",
  "type": "object",
  "required": ["id", "status", "created_at", "platforms", "ig_caption"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID (format: YYYY-MM-DD-NNN, e.g. 2026-04-15-001)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "approved", "scheduled", "posted", "failed"],
      "description": "draft=agent wrote it, ready=agent thinks it's good, approved=Joey approved, scheduled=queued in Upload-Post, posted=live, failed=posting error"
    },
    "campaign": {
      "type": ["string", "null"],
      "description": "Campaign name if part of one (e.g. 'summer-camp-2026')"
    },
    "content_type": {
      "type": "string",
      "enum": ["motivational", "class_promo", "coach_spotlight", "member_spotlight", "event", "behind_the_scenes", "schedule", "campaign", "announcement", "other"],
      "description": "What kind of post this is"
    },
    "post_date": {
      "type": ["string", "null"],
      "description": "Target publish date (YYYY-MM-DD)"
    },
    "post_time": {
      "type": ["string", "null"],
      "description": "Target publish time (HH:MM, ET). null = agent's best judgment"
    },
    "platforms": {
      "type": "array",
      "items": {"type": "string", "enum": ["instagram", "facebook", "threads", "linkedin"]},
      "description": "Which platforms to post to. DB content always includes instagram + facebook."
    },
    "ig_caption": {
      "type": "string",
      "description": "Full Instagram caption including hashtags"
    },
    "fb_caption": {
      "type": ["string", "null"],
      "description": "Facebook caption (≤255 chars). If null, truncated from ig_caption."
    },
    "hashtags": {
      "type": "array",
      "items": {"type": "string"},
      "maxItems": 5,
      "description": "Hashtags (max 5 for IG)"
    },
    "media_type": {
      "type": "string",
      "enum": ["photo", "video", "carousel", "text", "story"],
      "description": "What kind of media to attach"
    },
    "media_paths": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Absolute paths to media files (from media library index)"
    },
    "media_query": {
      "type": ["string", "null"],
      "description": "How the agent found these assets (e.g. 'boxing action, quality>=7, approved')"
    },
    "instagram_options": {
      "type": "object",
      "properties": {
        "media_type": {"type": "string", "enum": ["REELS", "STORIES", "IMAGE"]},
        "collaborators": {"type": ["string", "null"]},
        "first_comment": {"type": ["string", "null"]}
      },
      "description": "IG-specific posting options"
    },
    "facebook_options": {
      "type": "object",
      "properties": {
        "media_type": {"type": "string", "enum": ["REELS", "STORIES", "VIDEO"]}
      },
      "description": "FB-specific posting options"
    },
    "coach_tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Coach handles to tag (e.g. ['@gfitbyglenda', '@cjbean122'])"
    },
    "credit_videographer": {
      "type": "boolean",
      "description": "True if post uses @veteranwithacamera footage"
    },
    "notes": {
      "type": ["string", "null"],
      "description": "Internal notes (not posted)"
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when this entry was created"
    },
    "approved_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when Joey approved"
    },
    "posted_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when actually posted"
    },
    "post_result": {
      "type": ["object", "null"],
      "description": "Response from Upload-Post API after posting"
    }
  }
}
