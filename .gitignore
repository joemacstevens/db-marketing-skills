output/

# Nested independent repos (tracked in their own GitHub remotes)
Corecontrollandingpage/
node_modules

# OS noise
.DS_Store

# Editor / agent local config
.vscode/
.claude/

# Web-scrape cache (Firecrawl) — research, not source
.firecrawl/

# Reel project bytes — recipes (.fcpxml, src/, etc.) tracked; bytes go to Ajeo.
# These patterns target the specific directories where bytes accumulate;
# brand-kit/video-assets/ (hero loops, brand demos) is intentionally NOT excluded.
reels/out/
reels/**/out/
reels/**/raw-clips/
reels/**/client_videos/
reels/**/InBody-assets/
reels/**/public/clips/
# Loose camera files at the root of any reel project (e.g. sparring sub-reels)
reels/**/*.MP4
reels/**/*.MOV
# Exception: the daily ScheduleReel background clips are small (~4 MB each) and
# the nightly cron needs them, so they ride along in git for a clean mini deploy.
!reels/public/youth-invest/yi-open.mp4
!reels/public/youth-invest/yi-confidence.mp4

# Secrets — never commit
.env
.env.local
.env*.local
**/.env.local
**/.env*.local

# Raw API dumps from integration audits — may contain message copy
leads/integrations/*-audit-raw/

# Workspace-level archive staging (flushed to Ajeo periodically)
_archive/

# Workspace-level helper docs that shouldn't be tracked
hoist.sh
